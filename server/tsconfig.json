{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",

    "types": ["node"],
    "baseUrl": "./src",

    "paths": {
      "@config/*": ["config/*"],
      "@models/*": ["models/*"],
      "@repositories/*": ["repositories/*"],
      "@services/*": ["services/*"],
      "@controllers/*": ["controllers/*"],
      "@middlewares/*": ["middlewares/*"],
      "@utils/*": ["utils/*"],
      "@interfaces": ["interfaces/*"],
      "@dtos": ["dtos/*"],
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}

